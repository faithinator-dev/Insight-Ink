<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Insight-Ink</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Lora:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
</head>
<body>
    <nav class="navbar">
        <div class="container nav-container">
            <div class="nav-left">
                <a href="/" class="logo">Insight-Ink</a>
                <div class="search-bar">
                    <i class="fas fa-search"></i>
                    <input type="text" placeholder="Search">
                </div>
            </div>
            <div class="nav-right">
                <% if (user) { %>
                    <a href="/write" class="write-link"><i class="far fa-edit"></i> Write</a>
                    <button class="btn-icon"><i class="far fa-bell"></i></button>
                    <div class="profile-group">
                        <div class="profile-circle"><%= (user && user.name) ? user.name.charAt(0).toUpperCase() : 'U' %></div>
                        <a href="/logout" class="logout-link">Logout</a>
                    </div>
                <% } else { %>
                    <a href="/login" class="nav-link">Sign in</a>
                    <a href="/register" class="btn-primary">Get started</a>
                <% } %>
            </div>
        </div>
    </nav>
    <main class="container">
