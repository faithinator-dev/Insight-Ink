<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Insight-Ink</title>
    <link rel="stylesheet" href="/css/style.css">
    <script src="https://cdn.tiny.cloud/1/no-api-key/tinymce/6/tinymce.min.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Lora:wght@400;700&display=swap" rel="stylesheet">
</head>
<body>
    <header class="navbar">
        <div class="container nav-container">
            <div class="nav-left">
                <a href="/" class="logo">Insight Ink</a>
            </div>
            <div class="nav-right">
                <% if (user) { %>
                    <a href="/write" class="write-link"><i class="fas fa-pen-fancy"></i> Write</a>
                    <a href="/inbox" class="btn-icon" title="Inbox">
                        <i class="fas fa-bell"></i>
                        <% if (unreadNotifications && unreadNotifications > 0) { %>
                            <span style="position: absolute; top: -5px; right: -5px; background: #d93025; color: white; font-size: 0.7rem; padding: 2px 5px; border-radius: 10px; font-weight: bold;"><%= unreadNotifications > 9 ? '9+' : unreadNotifications %></span>
                        <% } %>
                    </a>
                    <div class="profile-group">
                        <button class="profile-trigger" id="profile-trigger">
                            <% if (user.profilePicture) { %>
                                <img src="<%= user.profilePicture %>" alt="<%= user.name %>" class="profile-circle" style="width: 32px; height: 32px; object-fit: cover;">
                            <% } else { %>
                                <div class="profile-circle"><%= user.name.charAt(0).toUpperCase() %></div>
                            <% } %>
                            <span class="profile-trigger-label"><%= user.name %></span>
                            <i class="fas fa-chevron-down profile-chevron"></i>
                        </button>
                        <nav class="profile-dropdown hidden" id="profile-dropdown">
                            <a href="/profile" class="profile-dropdown-link"><i class="fas fa-user"></i> Profile</a>
                            <a href="/inbox" class="profile-dropdown-link"><i class="fas fa-inbox"></i> Inbox</a>
                            <% if (user.role === 'admin' || user.role === 'superadmin') { %>
                                <a href="/super-admin" class="profile-dropdown-link"><i class="fas fa-crown"></i> Admin</a>
                            <% } %>
                            <a href="/logout" class="profile-dropdown-link danger"><i class="fas fa-sign-out-alt"></i> Logout</a>
                        </nav>
                    </div>
                <% } else { %>
                    <a href="/login" class="nav-link">Login</a>
                    <a href="/register" class="btn-primary">Sign Up</a>
                <% } %>
            </div>
        </div>
    </header>

    <main class="container">
        <script>
        const profileTrigger = document.getElementById('profile-trigger');
        const profileDropdown = document.getElementById('profile-dropdown');

        if (profileTrigger) {
            profileTrigger.addEventListener('click', () => {
                profileDropdown.classList.toggle('hidden');
            });

            document.addEventListener('click', (e) => {
                if (!profileTrigger.contains(e.target) && !profileDropdown.contains(e.target)) {
                    profileDropdown.classList.add('hidden');
                }
            });
        }
        </script>
