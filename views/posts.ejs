<%- include('partials/header') %>

<!-- Hero Section -->
<% if (!user) { %>
<div class="mb-12 bg-gradient-to-br from-indigo-50 to-blue-50 rounded-2xl border border-indigo-100 p-8 sm:p-12">
    <div class="max-w-2xl">
        <h1 class="text-4xl sm:text-5xl font-bold text-slate-900 mb-4">
            Discover stories, thinking, and expertise
        </h1>
        <p class="text-lg text-slate-600 mb-6">
            Explore insightful articles from writers and thinkers around the world.
        </p>
        <a href="/register" class="inline-block px-6 py-3 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 font-medium transition">
            Start exploring
        </a>
    </div>
</div>
<% } %>

<!-- Posts Grid -->
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    <% if (posts && posts.length > 0) { %>
        <% posts.forEach(post => { %>
            <% const isLiked = user && post.likes && post.likes.some(likeId => likeId.toString() === user._id.toString()); %>
            <% const likeCount = post.likes?.length || 0; %>
            <% const commentCount = post.comments?.length || 0; %>
            
            <!-- Post Card -->
            <article class="group bg-white rounded-xl border border-slate-200 overflow-hidden hover:shadow-lg hover:border-slate-300 transition-all duration-300">
                <!-- Featured Image -->
                <% if (post.imageData) { %>
                    <div class="h-40 bg-gradient-to-br from-slate-200 to-slate-300 overflow-hidden">
                        <img src="<%= post.imageData %>" alt="<%= post.title %>" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300">
                    </div>
                <% } %>
                
                <!-- Post Header -->
                <div class="p-5 border-b border-slate-100">
                    <div class="flex items-start justify-between mb-3">
                        <div class="flex items-center gap-3 flex-1">
                            <% if (post.authorId && post.authorId.profilePicture) { %>
                                <img src="<%= post.authorId.profilePicture %>" alt="<%= post.author %>" class="w-10 h-10 rounded-full object-cover">
                            <% } else { %>
                                <div class="w-10 h-10 bg-gradient-to-br from-indigo-400 to-indigo-600 rounded-full text-white text-sm font-bold flex items-center justify-center">
                                    <%= post.author.charAt(0).toUpperCase() %>
                                </div>
                            <% } %>
                            <div class="flex-1 min-w-0">
                                <p class="text-sm font-medium text-slate-900 truncate"><%= post.author %></p>
                                <p class="text-xs text-slate-500"><%= new Date(post.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) %></p>
                            </div>
                        </div>
                        
                        <!-- Edit/Delete Actions -->
                        <% if (user && post.authorId && (user._id.toString() === post.authorId.toString() || user.role === 'admin' || user.role === 'superadmin')) { %>
                            <div class="flex gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
                                <a href="/edit/<%= post._id %>" class="p-2 rounded text-slate-500 hover:bg-slate-100 hover:text-indigo-600 transition" title="Edit">
                                    <i class="fas fa-edit text-sm"></i>
                                </a>
                                <button onclick="deletePost('<%= post._id %>', <%= JSON.stringify(user._id.toString() === post.authorId.toString()) %>, '<%= user.role %>')" 
                                    class="p-2 rounded text-slate-500 hover:bg-red-50 hover:text-red-600 transition" title="Delete">
                                    <i class="fas fa-trash text-sm"></i>
                                </button>
                            </div>
                        <% } %>
                    </div>
                </div>

                <!-- Post Content -->
                <div class="p-5">
                    <h2 class="text-lg font-bold text-slate-900 mb-2 line-clamp-2 group-hover:text-indigo-600 transition">
                        <a href="/post/<%= post._id %>"><%= post.title %></a>
                    </h2>
                    <p class="text-sm text-slate-600 mb-4 line-clamp-2">
                        <%= post.excerpt || post.content.substring(0, 150) + '...' %>
                    </p>
                </div>

                <!-- Post Footer -->
                <div class="px-5 py-4 bg-slate-50 flex items-center justify-between">
                    <div class="flex items-center gap-3">
                        <% if (user) { %>
                            <button type="button" class="reaction-like flex items-center gap-1 text-xs font-medium text-slate-600 hover:text-red-600 transition"
                                data-post-id="<%= post._id %>" data-liked="<%= isLiked ? 'true' : 'false' %>">
                                <i class="<%= isLiked ? 'fas' : 'far' %> fa-heart"></i>
                                <span class="reaction-count"><%= likeCount %></span>
                            </button>
                        <% } else { %>
                            <a href="/login" class="flex items-center gap-1 text-xs font-medium text-slate-600 hover:text-red-600 transition">
                                <i class="far fa-heart"></i>
                                <span><%= likeCount %></span>
                            </a>
                        <% } %>
                        
                        <a href="/post/<%= post._id %>#comments" class="flex items-center gap-1 text-xs font-medium text-slate-600 hover:text-blue-600 transition">
                            <i class="far fa-comment"></i>
                            <span><%= commentCount %></span>
                        </a>
                    </div>
                    <span class="text-xs text-slate-500"><%= post.readTime || 5 %> min</span>
                </div>
            </article>
        <% }) %>
    <% } else { %>
        <!-- Empty State -->
        <div class="col-span-full py-16 text-center">
            <div class="w-16 h-16 bg-slate-100 rounded-full mx-auto mb-4 flex items-center justify-center">
                <i class="fas fa-feather text-2xl text-slate-400"></i>
            </div>
            <h3 class="text-lg font-semibold text-slate-900 mb-2">No posts yet</h3>
            <p class="text-slate-600 mb-4">Be the first to share your thoughts</p>
            <% if (user) { %>
                <a href="/write" class="inline-block px-4 py-2 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 font-medium transition text-sm">
                    Write your first post
                </a>
            <% } %>
        </div>
    <% } %>
</div>

<script>
document.querySelectorAll('.reaction-like').forEach((button) => {
    button.addEventListener('click', async () => {
        const postId = button.dataset.postId;

        try {
            const response = await fetch(`/api/posts/${postId}/like`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
            });

            const data = await response.json();
            if (!response.ok) {
                alert(data.message || 'Could not update like.');
                return;
            }

            const liked = Boolean(data.isLiked);
            button.dataset.liked = String(liked);
            button.dataset.count = String(data.likes);
            const icon = button.querySelector('i');
            const count = button.querySelector('.reaction-count');

            if (icon) {
                icon.className = liked ? 'fas fa-heart' : 'far fa-heart';
            }

            if (count) {
                count.textContent = String(data.likes);
            }

            button.style.color = liked ? 'var(--accent-color)' : 'var(--text-muted)';
        } catch (error) {
            console.error(error);
            alert('Could not update like.');
        }
    });
});

function requestDeleteReason(promptText) {
    return new Promise((resolve) => {
        const overlay = document.createElement('div');
        overlay.style.position = 'fixed';
        overlay.style.inset = '0';
        overlay.style.background = 'rgba(0, 0, 0, 0.55)';
        overlay.style.display = 'flex';
        overlay.style.alignItems = 'center';
        overlay.style.justifyContent = 'center';
        overlay.style.zIndex = '2000';

        const dialog = document.createElement('div');
        dialog.style.width = 'min(520px, calc(100vw - 32px))';
        dialog.style.background = 'var(--primary-bg)';
        dialog.style.border = '1px solid var(--border-color)';
        dialog.style.borderRadius = '16px';
        dialog.style.padding = '22px';
        dialog.style.boxShadow = '0 24px 60px rgba(0, 0, 0, 0.2)';

        const title = document.createElement('h3');
        title.textContent = 'Delete reason required';
        title.style.marginBottom = '10px';

        const description = document.createElement('p');
        description.textContent = promptText;
        description.style.color = 'var(--text-muted)';
        description.style.marginBottom = '12px';

        const textarea = document.createElement('textarea');
        textarea.placeholder = 'Type the reason for this deletion...';
        textarea.style.width = '100%';
        textarea.style.minHeight = '120px';
        textarea.style.resize = 'vertical';
        textarea.style.padding = '12px';
        textarea.style.border = '1px solid var(--border-color)';
        textarea.style.borderRadius = '12px';
        textarea.style.background = 'var(--secondary-bg)';
        textarea.style.color = 'var(--text-main)';
        textarea.style.marginBottom = '16px';

        const actions = document.createElement('div');
        actions.style.display = 'flex';
        actions.style.justifyContent = 'flex-end';
        actions.style.gap = '10px';

        const cancelButton = document.createElement('button');
        cancelButton.type = 'button';
        cancelButton.textContent = 'Cancel';
        cancelButton.className = 'btn-secondary mini';

        const confirmButton = document.createElement('button');
        confirmButton.type = 'button';
        confirmButton.textContent = 'Delete';
        confirmButton.className = 'btn-primary mini';

        const cleanup = () => {
            overlay.remove();
        };

        cancelButton.addEventListener('click', () => {
            cleanup();
            resolve(null);
        });

        confirmButton.addEventListener('click', () => {
            const value = textarea.value.trim();
            if (!value) {
                textarea.focus();
                textarea.style.borderColor = '#ff4d4d';
                return;
            }
            cleanup();
            resolve(value);
        });

        actions.append(cancelButton, confirmButton);
        dialog.append(title, description, textarea, actions);
        overlay.appendChild(dialog);
        document.body.appendChild(overlay);
        textarea.focus();
    });
}

async function deletePost(id, isOwner, role) {
    if (!confirm('Are you sure you want to delete this post?')) return;
    let deleteReason = '';

    if (!isOwner && (role === 'admin' || role === 'superadmin')) {
        deleteReason = await requestDeleteReason('Enter a reason for deleting this post. This will be shown to the post owner as a notification.');
        if (deleteReason === null) {
            return;
        }
    }

    try {
        const res = await fetch(`/api/posts/${id}`, {
            method: 'DELETE',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ deleteReason })
        });
        if (res.ok) location.reload();
        else {
            const data = await res.json();
            alert(data.message || 'Error deleting post');
        }
    } catch (err) {
        console.error(err);
    }
}
</script>

<%- include('partials/footer') %>
