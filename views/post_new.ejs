<%- include('partials/header') %>

<article class="min-h-screen bg-gradient-to-b from-white to-slate-50" data-id="<%= post._id %>">
    <!-- Article Container -->
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        
        <!-- Article Header -->
        <header class="mb-8">
            <!-- Meta Info -->
            <div class="flex items-center gap-2 text-sm text-slate-600 mb-4">
                <span><%= post.author %></span>
                <span>·</span>
                <span><%= new Date(post.createdAt).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }) %></span>
                <span>·</span>
                <span><%= post.readTime || 5 %> min read</span>
                <% if (user && post.authorId && (user._id.toString() === post.authorId.toString() || user.role === 'admin' || user.role === 'superadmin')) { %>
                    <span>·</span>
                    <a href="/edit/<%= post._id %>" class="text-indigo-600 hover:text-indigo-700 font-medium transition">Edit</a>
                    <span>·</span>
                    <button onclick="deletePost('<%= post._id %>', <%= JSON.stringify(user._id.toString() === post.authorId.toString()) %>, '<%= user.role %>')" class="text-red-600 hover:text-red-700 font-medium transition bg-none border-none cursor-pointer">Delete</button>
                <% } %>
            </div>
            
            <!-- Title -->
            <h1 class="text-4xl sm:text-5xl font-bold text-slate-900 mb-4 leading-tight">
                <%= post.title %>
            </h1>
            
            <!-- Excerpt -->
            <% if (post.excerpt) { %>
                <p class="text-lg text-slate-600 leading-relaxed">
                    <%= post.excerpt %>
                </p>
            <% } %>
        </header>

        <!-- Featured Image -->
        <% if (post.imageData) { %>
            <div class="mb-12">
                <img src="<%= post.imageData %>" alt="<%= post.title %>" class="w-full h-auto rounded-2xl shadow-lg">
            </div>
        <% } %>

        <!-- Article Content -->
        <div id="post-content" class="prose prose-sm sm:prose-base max-w-none mb-12 text-slate-700 leading-relaxed">
            <%- post.content %>
        </div>

        <!-- Divider -->
        <hr class="my-12 border-t-2 border-slate-200">

        <!-- Author Info & Actions -->
        <div class="bg-slate-50 rounded-2xl p-8 mb-12">
            <div class="flex items-center gap-4 mb-6">
                <% if (post.authorId && post.authorId.profilePicture) { %>
                    <img src="<%= post.authorId.profilePicture %>" alt="<%= post.author %>" class="w-16 h-16 rounded-full object-cover">
                <% } else { %>
                    <div class="w-16 h-16 bg-gradient-to-br from-indigo-400 to-indigo-600 rounded-full text-white text-2xl font-bold flex items-center justify-center">
                        <%= post.author.charAt(0).toUpperCase() %>
                    </div>
                <% } %>
                <div>
                    <h3 class="text-lg font-semibold text-slate-900"><%= post.author %></h3>
                    <p class="text-sm text-slate-600">@<%= post.authorId?.username || 'user' %></p>
                </div>
            </div>

            <!-- Action Buttons -->
            <div class="flex flex-wrap items-center gap-4">
                <% const isLiked = user && post.likes && post.likes.some(likeId => likeId.toString() === user._id.toString()); %>
                
                <% if (user) { %>
                    <button id="like-btn" class="flex items-center gap-2 px-4 py-2 rounded-lg border border-slate-200 hover:border-red-400 hover:bg-red-50 transition" style="color: <%= isLiked ? '#ef4444' : 'inherit' %>">
                        <i class="<%= isLiked ? 'fas' : 'far' %> fa-heart"></i>
                        <span id="like-count"><%= post.likes?.length || 0 %></span>
                        <span class="text-sm">Like</span>
                    </button>
                <% } else { %>
                    <a href="/login" class="flex items-center gap-2 px-4 py-2 rounded-lg border border-slate-200 hover:border-red-400 hover:bg-red-50 transition text-slate-700">
                        <i class="far fa-heart"></i>
                        <span><%= post.likes?.length || 0 %></span>
                        <span class="text-sm">Like</span>
                    </a>
                <% } %>

                <a href="#comments" class="flex items-center gap-2 px-4 py-2 rounded-lg border border-slate-200 hover:border-blue-400 hover:bg-blue-50 transition text-slate-700">
                    <i class="far fa-comment"></i>
                    <span><%= post.comments?.length || 0 %></span>
                    <span class="text-sm">Comment</span>
                </a>
            </div>
        </div>

        <!-- Comments Section -->
        <section id="comments" class="space-y-8">
            <div>
                <h2 class="text-2xl font-bold text-slate-900 mb-6">
                    Comments <span class="text-lg text-slate-600">(<span id="comment-count"><%= post.comments?.length || 0 %></span>)</span>
                </h2>
            </div>

            <!-- Comment Input -->
            <% if (user) { %>
                <div class="bg-white rounded-xl border border-slate-200 p-6 space-y-4">
                    <div class="flex gap-4">
                        <% if (user.profilePicture) { %>
                            <img src="<%= user.profilePicture %>" alt="<%= user.name %>" class="w-10 h-10 rounded-full object-cover flex-shrink-0">
                        <% } else { %>
                            <div class="w-10 h-10 bg-gradient-to-br from-indigo-400 to-indigo-600 rounded-full text-white text-sm font-bold flex items-center justify-center flex-shrink-0">
                                <%= user.name.charAt(0).toUpperCase() %>
                            </div>
                        <% } %>
                        <div class="flex-1">
                            <textarea 
                                id="comment-textarea" 
                                class="w-full px-4 py-3 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent resize-none"
                                placeholder="Share your thoughts..."
                                rows="3"
                            ></textarea>
                        </div>
                    </div>
                    <div class="flex justify-end">
                        <button id="send-comment-btn" class="px-6 py-2 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 font-medium transition">
                            Post Comment
                        </button>
                    </div>
                </div>
            <% } else { %>
                <div class="bg-slate-50 rounded-xl border border-slate-200 p-6 text-center">
                    <p class="text-slate-600 mb-4">Sign in to comment on this post</p>
                    <a href="/login" class="inline-block px-6 py-2 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 font-medium transition">
                        Sign In
                    </a>
                </div>
            <% } %>

            <!-- Comments List -->
            <div class="space-y-6" id="comments-list">
                <% if (post.comments && post.comments.length > 0) { %>
                    <% [...post.comments].reverse().forEach(comment => { %>
                        <div class="bg-white rounded-xl border border-slate-200 p-6" id="comment-<%= comment._id %>">
                            <div class="flex gap-4">
                                <!-- Commenter Avatar -->
                                <% if (comment.authorId && comment.authorId.profilePicture) { %>
                                    <img src="<%= comment.authorId.profilePicture %>" alt="<%= comment.author %>" class="w-10 h-10 rounded-full object-cover flex-shrink-0">
                                <% } else { %>
                                    <div class="w-10 h-10 bg-gradient-to-br from-slate-300 to-slate-500 rounded-full text-white text-sm font-bold flex items-center justify-center flex-shrink-0">
                                        <%= comment.author.charAt(0).toUpperCase() %>
                                    </div>
                                <% } %>

                                <div class="flex-1">
                                    <!-- Comment Header -->
                                    <div class="flex items-center justify-between mb-2">
                                        <div>
                                            <h4 class="font-semibold text-slate-900"><%= comment.author %></h4>
                                            <p class="text-sm text-slate-500"><%= new Date(comment.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></p>
                                        </div>
                                        
                                        <!-- Comment Actions -->
                                        <% if (user && (user._id.toString() === comment.authorId?.toString() || (post.authorId && user._id.toString() === post.authorId.toString()) || user.role === 'admin' || user.role === 'superadmin')) { %>
                                            <div class="flex gap-2">
                                                <button onclick="editComment('<%= comment._id %>')" class="text-sm text-indigo-600 hover:text-indigo-700 transition">Edit</button>
                                                <button onclick="deleteComment('<%= comment._id %>', <%= JSON.stringify(user._id.toString() === comment.authorId?.toString()) %>, '<%= user.role %>')" class="text-sm text-red-600 hover:text-red-700 transition">Delete</button>
                                            </div>
                                        <% } %>
                                    </div>

                                    <!-- Comment Text -->
                                    <p id="comment-text-<%= comment._id %>" class="text-slate-700 leading-relaxed mb-3">
                                        <%= comment.text %>
                                    </p>

                                    <!-- Edit Form (hidden) -->
                                    <div id="edit-comment-form-<%= comment._id %>" class="hidden space-y-3">
                                        <textarea class="w-full px-3 py-2 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500 resize-none" rows="2"><%= comment.text %></textarea>
                                        <div class="flex gap-2 justify-end">
                                            <button onclick="cancelEditComment('<%= comment._id %>')" class="px-3 py-1 text-sm text-slate-600 hover:bg-slate-100 rounded transition">Cancel</button>
                                            <button onclick="saveEditComment('<%= comment._id %>')" class="px-3 py-1 text-sm bg-indigo-600 text-white rounded hover:bg-indigo-700 transition">Save</button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                <% } else { %>
                    <div class="text-center py-8">
                        <p class="text-slate-500">No comments yet. Be the first to comment!</p>
                    </div>
                <% } %>
            </div>
        </section>
    </div>
</article>

<style>
    #post-content {
        font-size: 1.1rem;
        line-height: 1.8;
        color: #1e293b;
    }

    #post-content h1, #post-content h2, #post-content h3 {
        font-weight: bold;
        margin-top: 1.5em;
        margin-bottom: 0.5em;
        color: #0f172a;
    }

    #post-content h1 { font-size: 2em; }
    #post-content h2 { font-size: 1.5em; }
    #post-content h3 { font-size: 1.25em; }

    #post-content p {
        margin-bottom: 1em;
    }

    #post-content ul, #post-content ol {
        margin: 1em 0;
        margin-left: 1.5em;
        line-height: 1.8;
    }

    #post-content li {
        margin-bottom: 0.5em;
    }

    #post-content blockquote {
        border-left: 4px solid #6366f1;
        padding-left: 1em;
        margin: 1em 0;
        color: #64748b;
        font-style: italic;
    }

    #post-content code {
        background: #f1f5f9;
        padding: 0.2em 0.4em;
        border-radius: 0.3em;
        font-family: 'Courier New', monospace;
        color: #dc2626;
    }

    #post-content pre {
        background: #1e293b;
        color: #f1f5f9;
        padding: 1em;
        border-radius: 0.5em;
        overflow-x: auto;
        margin: 1em 0;
    }

    #post-content pre code {
        background: none;
        color: inherit;
        padding: 0;
    }

    #post-content img {
        max-width: 100%;
        height: auto;
        border-radius: 0.5em;
        margin: 1em 0;
    }

    #post-content a {
        color: #6366f1;
        text-decoration: underline;
    }

    #post-content a:hover {
        color: #4f46e5;
    }

    #post-content table {
        width: 100%;
        border-collapse: collapse;
        margin: 1em 0;
    }

    #post-content th, #post-content td {
        border: 1px solid #e2e8f0;
        padding: 0.75em;
        text-align: left;
    }

    #post-content th {
        background: #f8fafc;
        font-weight: bold;
    }
</style>

<script>
// Like button functionality
<% if (user) { %>
const likeBtn = document.getElementById('like-btn');
if (likeBtn) {
    likeBtn.addEventListener('click', async () => {
        try {
            const response = await fetch(`/api/posts/<%= post._id %>/like`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
            });

            const data = await response.json();
            if (!response.ok) {
                alert(data.message || 'Could not update like');
                return;
            }

            const liked = Boolean(data.isLiked);
            const icon = likeBtn.querySelector('i');
            const count = likeBtn.querySelector('#like-count');

            icon.className = liked ? 'fas fa-heart' : 'far fa-heart';
            count.textContent = String(data.likes);
            likeBtn.style.color = liked ? '#ef4444' : 'inherit';

        } catch (error) {
            console.error(error);
            alert('Could not update like');
        }
    });
}
<% } %>

// Comment functionality
<% if (user) { %>
const commentBtn = document.getElementById('send-comment-btn');
const commentTextarea = document.getElementById('comment-textarea');

if (commentBtn) {
    commentBtn.addEventListener('click', async () => {
        const text = commentTextarea.value.trim();
        if (!text) {
            alert('Please enter a comment');
            return;
        }

        try {
            const response = await fetch(`/api/posts/<%= post._id %>/comment`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ text })
            });

            const data = await response.json();
            if (response.ok) {
                location.reload();
            } else {
                alert(data.message || 'Error posting comment');
            }
        } catch (error) {
            console.error(error);
            alert('Error posting comment');
        }
    });
}
<% } %>

// Delete post
async function deletePost(id, isOwner, role) {
    if (!confirm('Are you sure you want to delete this post?')) return;
    let deleteReason = '';

    if (!isOwner && (role === 'admin' || role === 'superadmin')) {
        deleteReason = prompt('Enter a reason for deleting this post:');
        if (!deleteReason) return;
    }

    try {
        const response = await fetch(`/api/posts/${id}`, {
            method: 'DELETE',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ deleteReason })
        });

        if (response.ok) {
            window.location.href = '/';
        } else {
            const data = await response.json();
            alert(data.message || 'Error deleting post');
        }
    } catch (error) {
        console.error(error);
    }
}

// Edit comment
function editComment(commentId) {
    const textEl = document.getElementById(`comment-text-${commentId}`);
    const formEl = document.getElementById(`edit-comment-form-${commentId}`);
    if (textEl && formEl) {
        textEl.classList.add('hidden');
        formEl.classList.remove('hidden');
    }
}

function cancelEditComment(commentId) {
    const textEl = document.getElementById(`comment-text-${commentId}`);
    const formEl = document.getElementById(`edit-comment-form-${commentId}`);
    if (textEl && formEl) {
        formEl.classList.add('hidden');
        textEl.classList.remove('hidden');
    }
}

async function saveEditComment(commentId) {
    const formEl = document.getElementById(`edit-comment-form-${commentId}`);
    const textarea = formEl.querySelector('textarea');
    const newText = textarea.value.trim();

    if (!newText) {
        alert('Comment cannot be empty');
        return;
    }

    try {
        const response = await fetch(`/api/posts/<%= post._id %>/comment/${commentId}`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ text: newText })
        });

        const data = await response.json();
        if (response.ok) {
            const textEl = document.getElementById(`comment-text-${commentId}`);
            textEl.textContent = newText;
            formEl.classList.add('hidden');
            textEl.classList.remove('hidden');
        } else {
            alert(data.message || 'Error updating comment');
        }
    } catch (error) {
        console.error(error);
        alert('Error updating comment');
    }
}

// Delete comment
async function deleteComment(commentId, isOwner, role) {
    if (!confirm('Delete this comment?')) return;

    try {
        const response = await fetch(`/api/posts/<%= post._id %>/comment/${commentId}`, {
            method: 'DELETE',
            headers: { 'Content-Type': 'application/json' }
        });

        if (response.ok) {
            const commentEl = document.getElementById(`comment-${commentId}`);
            if (commentEl) commentEl.remove();
            const count = document.getElementById('comment-count');
            if (count) {
                count.textContent = String(parseInt(count.textContent) - 1);
            }
        } else {
            const data = await response.json();
            alert(data.message || 'Error deleting comment');
        }
    } catch (error) {
        console.error(error);
        alert('Error deleting comment');
    }
}
</script>

<%- include('partials/footer') %>
