<%- include('partials/header') %>

<% const mailNotices = typeof recentNotices !== 'undefined' && Array.isArray(recentNotices) ? recentNotices : []; %>

<div class="super-admin-container">
    <header class="admin-header">
        <div class="header-main">
            <span class="eyebrow"><i class="icon">🛡️</i> System Operations</span>
            <h1>Operations Dashboard</h1>
            <p class="subtitle">Platform-wide overview and administrative controls.</p>
        </div>
        <div class="admin-badge">
            <div class="badge-icon">👑</div>
            <div class="badge-text">
                <span class="label">Access Level</span>
                <span class="value"><%= user.role %></span>
            </div>
        </div>
    </header>

    <main class="admin-content">
        <!-- Key Metrics -->
        <section class="stats-overview">
            <div class="stat-card primary">
                <div class="stat-icon">👥</div>
                <div class="stat-info">
                    <span class="stat-label">Total Users</span>
                    <strong class="stat-value"><%= metrics.userCount %></strong>
                </div>
                <div class="stat-breakdown">
                    <span><%= metrics.adminCount %> Admins</span>
                    <span><%= metrics.superAdminCount %> Super</span>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon">📝</div>
                <div class="stat-info">
                    <span class="stat-label">Total Posts</span>
                    <strong class="stat-value"><%= metrics.postCount %></strong>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon">💬</div>
                <div class="stat-info">
                    <span class="stat-label">Engagement</span>
                    <strong class="stat-value"><%= metrics.totalComments %></strong>
                </div>
                <div class="stat-sub">Comments</div>
            </div>
            <div class="stat-card">
                <div class="stat-icon">📈</div>
                <div class="stat-info">
                    <span class="stat-label">Unique Visitors</span>
                    <strong class="stat-value"><%= metrics.visitorCount %></strong>
                </div>
                <div class="stat-sub">Past 7 days</div>
            </div>
        </section>

        <div class="admin-layout-grid">
            <!-- Left Column: Activity & Communication -->
            <div class="grid-column">
                <article class="content-panel">
                    <div class="panel-header">
                        <div class="panel-title-group">
                            <h2>Recent Activity</h2>
                            <span class="panel-tag"><%= recentActivities.length %> Events</span>
                        </div>
                        <button class="view-all-btn">Refresh</button>
                    </div>
                    <div class="activity-feed">
                        <% if (recentActivities.length > 0) { %>
                            <% recentActivities.forEach(activity => { %>
                                <div class="activity-item">
                                    <div class="activity-marker" data-type="<%= activity.type %>"></div>
                                    <div class="activity-body">
                                        <div class="activity-header">
                                            <strong><%= activity.action.replace(/_/g, ' ') %></strong>
                                            <time><%= new Date(activity.createdAt).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) %></time>
                                        </div>
                                        <p class="activity-desc">
                                            <span class="user-pill"><%= activity.userName || 'System' %></span> 
                                            performed action on <em><%= activity.entityType %></em>
                                        </p>
                                    </div>
                                </div>
                            <% }) %>
                        <% } else { %>
                            <div class="empty-state">
                                <p>No recent activity detected.</p>
                            </div>
                        <% } %>
                    </div>
                </article>

                <article class="content-panel highlight">
                    <div class="panel-header">
                        <h2>Direct Communication</h2>
                    </div>
                    <form id="notice-form" class="admin-form">
                        <p class="form-help">Send a secure system notice to a user's registered email or a target group.</p>
                        
                        <div class="form-row">
                            <div class="field-group">
                                <label for="targetId">Target Recipient or Group</label>
                                <div class="select-wrapper">
                                    <select name="targetId" id="targetId" required>
                                        <optgroup label="Groups">
                                            <option value="group:all">Everyone (All Roles)</option>
                                            <option value="group:admins">Admins & Super Admins</option>
                                            <option value="group:users">Standard Users Only</option>
                                        </optgroup>
                                        <optgroup label="Individual Users">
                                            <% allUsers.forEach(account => { %>
                                                <option value="user:<%= account._id %>" <%= account.email ? '' : 'disabled' %>>
                                                    <%= account.name || account.username %> (<%= account.email || 'No email' %>)
                                                </option>
                                            <% }) %>
                                        </optgroup>
                                    </select>
                                </div>
                            </div>
                        </div>

                        <div class="form-row">
                            <div class="field-group">
                                <label for="subject">Notice Subject</label>
                                <input type="text" name="subject" id="subject" placeholder="e.g., Account Verification Needed" required>
                            </div>
                        </div>

                        <div class="form-row">
                            <div class="field-group">
                                <label for="message">Detailed Message</label>
                                <textarea name="message" id="message" rows="4" placeholder="Type your message here..." required></textarea>
                            </div>
                        </div>

                        <button type="submit" class="primary-btn" id="submit-notice-btn">
                            <span>Send Notice</span>
                            <i class="icon">✉️</i>
                        </button>
                    </form>
                </article>
            </div>

            <!-- Right Column: User Management & Content -->
            <div class="grid-column">
                <article class="content-panel">
                    <div class="panel-header">
                        <div class="panel-title-group">
                            <h2>User Directory</h2>
                            <span class="panel-tag">Management</span>
                        </div>
                    </div>
                    <div class="user-list">
                        <% recentUsers.forEach(account => { %>
                            <div class="user-card">
                                <div class="user-info">
                                    <div class="user-avatar" style="background-color: <%= account.role === 'admin' ? '#4a90e2' : account.role === 'superadmin' ? '#f5a623' : '#7ed321' %>">
                                        <%= (account.name || account.username || '?').charAt(0).toUpperCase() %>
                                    </div>
                                    <div class="user-details">
                                        <strong><%= account.name || account.username %></strong>
                                        <span><%= account.email %></span>
                                    </div>
                                </div>
                                <div class="user-actions">
                                    <span class="role-badge" data-role="<%= account.role %>"><%= account.role %></span>
                                    <% if (account.role === 'user') { %>
                                        <button type="button" class="action-icon-btn promote-btn" data-user-id="<%= account._id %>" title="Promote to Admin">
                                            ⏫
                                        </button>
                                    <% } %>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                </article>

                <article class="content-panel">
                    <div class="panel-header">
                        <h2>Latest Posts</h2>
                    </div>
                    <div class="admin-post-list">
                        <% recentPosts.forEach(post => { %>
                            <a href="/post/<%= post._id %>" class="admin-post-item">
                                <div class="post-info">
                                    <span class="post-title"><%= post.title %></span>
                                    <span class="post-meta">By <%= post.author %> · <%= new Date(post.createdAt).toLocaleDateString() %></span>
                                </div>
                                <div class="post-stats">
                                    <span>💬 <%= (post.comments || []).length %></span>
                                </div>
                            </a>
                        <% }) %>
                    </div>
                </article>
            </div>
        </div>
    </main>
</div>

<style>
/* Layout & Container */
.super-admin-container {
    max-width: 1400px;
    margin: 40px auto;
    padding: 0 24px;
    font-family: var(--font-sans);
}

.admin-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 40px;
}

.header-main h1 {
    font-family: var(--font-serif);
    font-size: 2.5rem;
    margin: 8px 0;
    color: var(--text-main);
}

.eyebrow {
    display: flex;
    align-items: center;
    gap: 8px;
    text-transform: uppercase;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 1px;
    color: var(--accent-color);
}

.subtitle {
    color: var(--text-muted);
    font-size: 1.1rem;
}

.admin-badge {
    display: flex;
    align-items: center;
    gap: 16px;
    background: var(--secondary-bg);
    padding: 12px 20px;
    border-radius: 16px;
    border: 1px solid var(--border-color);
}

.badge-icon {
    font-size: 1.5rem;
}

.badge-text .label {
    display: block;
    font-size: 0.7rem;
    color: var(--text-muted);
    text-transform: uppercase;
}

.badge-text .value {
    font-weight: 700;
    font-size: 1rem;
    color: var(--text-main);
}

/* Stats Overview */
.stats-overview {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 20px;
    margin-bottom: 40px;
}

.stat-card {
    background: var(--primary-bg);
    border: 1px solid var(--border-color);
    border-radius: 20px;
    padding: 24px;
    display: flex;
    flex-direction: column;
    position: relative;
    overflow: hidden;
    transition: transform 0.2s, box-shadow 0.2s;
}

.stat-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 24px rgba(0,0,0,0.06);
}

.stat-card.primary {
    background: linear-gradient(135deg, var(--accent-color), #2d3436);
    color: white;
    border: none;
}

.stat-card.primary .stat-label,
.stat-card.primary .stat-sub {
    color: rgba(255,255,255,0.7);
}

.stat-icon {
    font-size: 1.5rem;
    margin-bottom: 16px;
}

.stat-label {
    font-size: 0.85rem;
    color: var(--text-muted);
    font-weight: 600;
}

.stat-value {
    font-size: 2.2rem;
    font-family: var(--font-serif);
    display: block;
    margin: 4px 0;
}

.stat-breakdown {
    display: flex;
    gap: 12px;
    font-size: 0.75rem;
    margin-top: 12px;
    opacity: 0.8;
}

.stat-sub {
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-top: 8px;
}

/* Grid Layout */
.admin-layout-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 30px;
    align-items: start;
}

.grid-column {
    display: flex;
    flex-direction: column;
    gap: 30px;
}

/* Panels */
.content-panel {
    background: var(--primary-bg);
    border: 1px solid var(--border-color);
    border-radius: 24px;
    padding: 30px;
    box-shadow: 0 4px 6px rgba(0,0,0,0.02);
}

.content-panel.highlight {
    background: var(--secondary-bg);
    border-color: var(--accent-color);
    border-width: 2px;
}

.panel-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 24px;
}

.panel-title-group h2 {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    margin-bottom: 4px;
}

.panel-tag {
    font-size: 0.7rem;
    background: var(--secondary-bg);
    padding: 4px 10px;
    border-radius: 20px;
    color: var(--text-muted);
    font-weight: 700;
    text-transform: uppercase;
}

/* Activity Feed */
.activity-feed {
    display: flex;
    flex-direction: column;
    gap: 20px;
}

.activity-item {
    display: flex;
    gap: 16px;
    position: relative;
}

.activity-marker {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: #dfe6e9;
    margin-top: 6px;
    flex-shrink: 0;
}

.activity-marker[data-type="post"] { background: var(--accent-color); }
.activity-marker[data-type="auth"] { background: #0984e3; }
.activity-marker[data-type="comment"] { background: #fdcb6e; }

.activity-body {
    flex: 1;
}

.activity-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.activity-header strong {
    font-size: 0.95rem;
    text-transform: capitalize;
}

.activity-header time {
    font-size: 0.75rem;
    color: var(--text-muted);
}

.activity-desc {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-top: 4px;
}

.user-pill {
    background: var(--secondary-bg);
    padding: 2px 8px;
    border-radius: 4px;
    font-weight: 600;
    color: var(--text-main);
}

/* Forms */
.admin-form {
    display: flex;
    flex-direction: column;
    gap: 20px;
}

.form-help {
    font-size: 0.9rem;
    color: var(--text-muted);
    margin-bottom: 10px;
}

.field-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
}

.field-group label {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--text-main);
}

.admin-form input,
.admin-form select,
.admin-form textarea {
    padding: 12px 16px;
    border: 1.5px solid var(--border-color);
    border-radius: 12px;
    background: var(--primary-bg);
    font-family: inherit;
    font-size: 0.95rem;
    transition: border-color 0.2s;
}

.admin-form input:focus,
.admin-form select:focus,
.admin-form textarea:focus {
    outline: none;
    border-color: var(--accent-color);
}

.primary-btn {
    background: var(--text-main);
    color: white;
    border: none;
    padding: 14px 24px;
    border-radius: 12px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    cursor: pointer;
    transition: opacity 0.2s;
}

.primary-btn:hover {
    opacity: 0.9;
}

/* User List */
.user-list {
    display: flex;
    flex-direction: column;
    gap: 16px;
}

.user-card {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px;
    border: 1px solid var(--border-color);
    border-radius: 16px;
    transition: background-color 0.2s;
}

.user-card:hover {
    background-color: var(--secondary-bg);
}

.user-info {
    display: flex;
    align-items: center;
    gap: 12px;
}

.user-avatar {
    width: 40px;
    height: 40px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-weight: 700;
}

.user-details strong {
    display: block;
    font-size: 0.95rem;
}

.user-details span {
    font-size: 0.8rem;
    color: var(--text-muted);
}

.user-actions {
    display: flex;
    align-items: center;
    gap: 12px;
}

.role-badge {
    font-size: 0.7rem;
    font-weight: 800;
    text-transform: uppercase;
    padding: 4px 8px;
    border-radius: 6px;
    background: #eee;
}

.role-badge[data-role="superadmin"] { background: #fff3cd; color: #856404; }
.role-badge[data-role="admin"] { background: #cce5ff; color: #004085; }
.role-badge[data-role="user"] { background: #d4edda; color: #155724; }

.action-icon-btn {
    background: none;
    border: none;
    font-size: 1.1rem;
    cursor: pointer;
    padding: 4px;
    border-radius: 8px;
    transition: background-color 0.2s;
}

.action-icon-btn:hover {
    background-color: rgba(0,0,0,0.05);
}

/* Posts List */
.admin-post-list {
    display: flex;
    flex-direction: column;
}

.admin-post-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px 0;
    border-bottom: 1px solid var(--border-color);
    text-decoration: none;
    color: inherit;
}

.admin-post-item:last-child {
    border-bottom: none;
}

.admin-post-item:hover .post-title {
    color: var(--accent-color);
    text-decoration: underline;
}

.post-title {
    display: block;
    font-weight: 600;
    margin-bottom: 4px;
}

.post-meta {
    font-size: 0.8rem;
    color: var(--text-muted);
}

.post-stats {
    font-size: 0.85rem;
    color: var(--text-muted);
}

/* Responsive */
@media (max-width: 1100px) {
    .admin-layout-grid {
        grid-template-columns: 1fr;
    }
}

@media (max-width: 768px) {
    .admin-header {
        flex-direction: column;
        align-items: flex-start;
        gap: 20px;
    }
    
    .super-admin-container {
        padding: 0 16px;
    }
    
    .header-main h1 {
        font-size: 2rem;
    }
}
</style>

<script>
document.querySelectorAll('.promote-btn').forEach((button) => {
    button.addEventListener('click', async () => {
        if (!confirm('Promote this user to admin?')) {
            return;
        }

        try {
            const response = await fetch(`/super-admin/users/${button.dataset.userId}/promote`, { method: 'POST' });
            const data = await response.json();
            if (response.ok) {
                window.location.reload();
            } else {
                alert(data.message || 'Could not promote user.');
            }
        } catch (error) {
            console.error(error);
            alert('Could not promote user.');
        }
    });
});

const noticeForm = document.getElementById('notice-form');

if (noticeForm) {
    noticeForm.addEventListener('submit', async (event) => {
        event.preventDefault();

        const submitBtn = document.getElementById('submit-notice-btn');
        const formData = new FormData(noticeForm);
        const targetValue = formData.get('targetId'); // Format: "type:id"
        const subject = formData.get('subject');
        const message = formData.get('message');

        if (!targetValue) {
            alert('Choose a recipient or group first.');
            return;
        }

        const [type, id] = targetValue.split(':');
        let endpoint = '';
        let body = { subject, message };

        if (type === 'group') {
            endpoint = '/super-admin/group-notice';
            body.target = id;
        } else {
            endpoint = `/super-admin/users/${id}/notice`;
        }

        try {
            submitBtn.disabled = true;
            submitBtn.querySelector('span').textContent = 'Sending...';

            const response = await fetch(endpoint, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(body),
            });

            const data = await response.json();
            if (response.ok) {
                noticeForm.reset();
                alert(data.message || 'Notice sent successfully.');
            } else {
                alert(data.message || 'Could not send notice.');
            }
        } catch (error) {
            console.error(error);
            alert('An error occurred while sending the notice.');
        } finally {
            submitBtn.disabled = false;
            submitBtn.querySelector('span').textContent = 'Send Notice';
        }
    });
}
</script>

<%- include('partials/footer') %>