<%- include('partials/header') %>

<% const mailNotices = typeof recentNotices !== 'undefined' && Array.isArray(recentNotices) ? recentNotices : []; %>

<div class="super-admin-page">
    <section class="portal-hero">
        <div>
            <p class="eyebrow">Super admin portal</p>
            <h1>Operations Dashboard</h1>
            <p class="portal-intro">Monitor users, admins, posts, visitors, and activity from one place.</p>
        </div>
        <div class="portal-badge">
            <span>Role</span>
            <strong><%= user.role %></strong>
        </div>
    </section>

    <section class="metric-grid">
        <article class="metric-card accent"><span>Total users</span><strong><%= metrics.userCount %></strong></article>
        <article class="metric-card"><span>Admins</span><strong><%= metrics.adminCount %></strong></article>
        <article class="metric-card"><span>Super admins</span><strong><%= metrics.superAdminCount %></strong></article>
        <article class="metric-card"><span>Posts</span><strong><%= metrics.postCount %></strong></article>
        <article class="metric-card"><span>Comments</span><strong><%= metrics.totalComments %></strong></article>
        <article class="metric-card"><span>Likes</span><strong><%= metrics.totalLikes %></strong></article>
        <article class="metric-card"><span>Unique visitors (7 days)</span><strong><%= metrics.visitorCount %></strong></article>
    </section>

    <section class="portal-grid">
        <article class="panel">
            <div class="panel-header">
                <h2>Recent activity</h2>
                <span><%= recentActivities.length %> events</span>
            </div>
            <div class="activity-list">
                <% if (recentActivities.length > 0) { %>
                    <% recentActivities.forEach(activity => { %>
                        <div class="activity-row">
                            <div class="activity-main">
                                <strong><%= activity.action %></strong>
                                <p><%= activity.userName || 'Anonymous visitor' %><% if (activity.path) { %> · <%= activity.path %><% } %></p>
                            </div>
                            <div class="activity-meta">
                                <span><%= activity.type %></span>
                                <time><%= new Date(activity.createdAt).toLocaleString() %></time>
                            </div>
                        </div>
                    <% }) %>
                <% } else { %>
                    <p class="empty-state">No activity yet.</p>
                <% } %>
            </div>
        </article>

        <article class="panel">
            <div class="panel-header">
                <h2>Admins</h2>
                <span><%= adminUsers.length %> total</span>
            </div>
            <div class="table-list">
                <% if (adminUsers.length > 0) { %>
                    <% adminUsers.forEach(admin => { %>
                        <div class="table-row">
                            <div>
                                <strong><%= admin.name %></strong>
                                <p>@<%= admin.username %> · <%= admin.email %></p>
                            </div>
                            <div class="row-meta">
                                <span>admin</span>
                                <time><%= new Date(admin.createdAt).toLocaleDateString() %></time>
                            </div>
                        </div>
                    <% }) %>
                <% } else { %>
                    <p class="empty-state">No admins found.</p>
                <% } %>
            </div>
        </article>
    </section>

    <section class="portal-grid single">
        <article class="panel">
            <div class="panel-header">
                <h2>Recent users</h2>
                <span><%= recentUsers.length %> shown</span>
            </div>
            <div class="table-list">
                <% recentUsers.forEach(account => { %>
                    <div class="table-row">
                        <div>
                            <strong><%= account.name %></strong>
                            <p>@<%= account.username %> · <%= account.email %></p>
                        </div>
                        <div class="row-actions">
                            <div class="row-meta">
                                <span><%= account.role %></span>
                                <time><%= new Date(account.createdAt).toLocaleDateString() %></time>
                            </div>
                            <% if (account.role !== 'superadmin' && account.role !== 'admin') { %>
                                <button type="button" class="promote-btn" data-user-id="<%= account._id %>">Promote to admin</button>
                            <% } %>
                        </div>
                    </div>
                <% }) %>
            </div>
        </article>
    </section>

    <section class="portal-grid single">
        <article class="panel notice-panel">
            <div class="panel-header">
                <h2>Send customizable email to user</h2>
                <span>Super admin only</span>
            </div>
            <form id="notice-form" class="notice-form">
                <p class="notice-help">
                    Compose a custom subject and message, then send it to the selected user's email inbox.
                </p>
                <label>
                    Recipient
                    <select name="userId" required>
                        <option value="">Choose a user</option>
                        <% allUsers.forEach(account => { %>
                            <option value="<%= account._id %>" <%= account.email ? '' : 'disabled' %>><%= account.name || account.username || account.email || 'User' %> (@<%= account.username || 'no-username' %>) · <%= account.email || 'no-email' %> · <%= account.role %></option>
                        <% }) %>
                    </select>
                    <small>Only users with an email address can receive mail.</small>
                </label>

                <label>
                    Subject
                    <input type="text" name="subject" placeholder="Policy update, reminder, approval..." required>
                </label>

                <label>
                    Message
                    <textarea name="message" rows="5" placeholder="Write the email message the user should receive." required></textarea>
                </label>

                <button type="submit" class="promote-btn notice-submit-btn">Send email</button>
            </form>
        </article>
    </section>

    <section class="portal-grid single">
        <article class="panel">
            <div class="panel-header">
                <h2>Recent mail notices</h2>
                <span><%= mailNotices.length %> shown</span>
            </div>
            <div class="table-list">
                <% if (mailNotices.length > 0) { %>
                    <% mailNotices.forEach(notice => { %>
                        <div class="table-row notice-row">
                            <div>
                                <strong><%= notice.title %></strong>
                                <p>
                                    To <%= notice.userId && notice.userId.name ? notice.userId.name : 'Unknown user' %>
                                    <% if (notice.userId && notice.userId.email) { %>
                                        · <%= notice.userId.email %>
                                    <% } %>
                                </p>
                                <p class="notice-message"><%= notice.message %></p>
                            </div>
                            <div class="row-meta">
                                <span><%= notice.read ? 'read' : 'unread' %></span>
                                <time><%= new Date(notice.createdAt).toLocaleString() %></time>
                            </div>
                        </div>
                    <% }) %>
                <% } else { %>
                    <p class="empty-state">No admin notices have been sent yet.</p>
                <% } %>
            </div>
        </article>
    </section>

    <section class="portal-grid single">
        <article class="panel">
            <div class="panel-header">
                <h2>Recent posts</h2>
                <span><%= recentPosts.length %> shown</span>
            </div>
            <div class="table-list">
                <% recentPosts.forEach(post => { %>
                    <div class="table-row">
                        <div>
                            <strong><a href="/post/<%= post._id %>"><%= post.title %></a></strong>
                            <p><%= post.author %></p>
                        </div>
                        <div class="row-meta">
                            <span><%= (post.comments || []).length %> comments</span>
                            <time><%= new Date(post.createdAt).toLocaleDateString() %></time>
                        </div>
                    </div>
                <% }) %>
            </div>
        </article>
    </section>
</div>

<style>
.super-admin-page { max-width: 1240px; margin: 36px auto 60px; }
.portal-hero { display: flex; justify-content: space-between; gap: 24px; align-items: flex-start; margin-bottom: 24px; }
.eyebrow { text-transform: uppercase; letter-spacing: 0.12em; color: var(--accent-color); font-size: 0.75rem; margin-bottom: 10px; }
.portal-hero h1 { font-family: var(--font-serif); font-size: clamp(2rem, 5vw, 3.5rem); margin-bottom: 10px; }
.portal-intro { color: var(--text-muted); max-width: 620px; }
.portal-badge { background: var(--primary-bg); border: 1px solid var(--border-color); border-radius: 16px; padding: 16px 18px; min-width: 170px; text-align: right; box-shadow: 0 10px 24px rgba(0, 0, 0, 0.05); }
.portal-badge span { display: block; color: var(--text-muted); font-size: 0.8rem; margin-bottom: 4px; }
.metric-grid { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 16px; margin-bottom: 24px; }
.metric-card { background: var(--primary-bg); border: 1px solid var(--border-color); border-radius: 18px; padding: 18px; box-shadow: 0 10px 24px rgba(0, 0, 0, 0.04); }
.metric-card span { display: block; color: var(--text-muted); font-size: 0.85rem; margin-bottom: 14px; }
.metric-card strong { font-size: 2rem; font-family: var(--font-serif); }
.metric-card.accent { background: linear-gradient(135deg, rgba(74, 144, 226, 0.12), rgba(124, 196, 255, 0.12)); }
.portal-grid { display: grid; grid-template-columns: 1.4fr 1fr; gap: 18px; margin-bottom: 18px; }
.portal-grid.single { grid-template-columns: 1fr; }
.panel { background: var(--primary-bg); border: 1px solid var(--border-color); border-radius: 20px; padding: 22px; box-shadow: 0 10px 24px rgba(0, 0, 0, 0.04); }
.panel-header { display: flex; justify-content: space-between; gap: 16px; align-items: baseline; margin-bottom: 16px; }
.panel-header h2 { font-family: var(--font-serif); }
.panel-header span { color: var(--text-muted); font-size: 0.85rem; }
.activity-list, .table-list { display: grid; gap: 12px; }
.activity-row, .table-row { display: flex; justify-content: space-between; gap: 16px; padding: 14px 0; border-top: 1px solid var(--border-color); }
.activity-row:first-child, .table-row:first-child { border-top: none; padding-top: 0; }
.activity-main strong, .table-row strong a { color: var(--text-main); text-decoration: none; }
.activity-main p, .table-row p { color: var(--text-muted); font-size: 0.9rem; margin-top: 4px; }
.notice-message { color: var(--text-main); margin-top: 8px; white-space: pre-wrap; }
.activity-meta, .row-meta { text-align: right; color: var(--text-muted); font-size: 0.82rem; display: grid; gap: 4px; align-content: center; }
.row-actions { display: grid; justify-items: end; gap: 10px; }
.promote-btn { border: 1px solid var(--border-color); background: var(--secondary-bg); color: var(--text-main); border-radius: 999px; padding: 8px 12px; cursor: pointer; }
.notice-form { display: grid; gap: 16px; }
.notice-help { color: var(--text-muted); font-size: 0.92rem; line-height: 1.5; }
.notice-form label { display: grid; gap: 8px; font-size: 0.92rem; color: var(--text-muted); }
.notice-form small { color: var(--text-muted); font-size: 0.8rem; }
.notice-form input, .notice-form select, .notice-form textarea { width: 100%; border: 1px solid var(--border-color); border-radius: 12px; background: var(--secondary-bg); color: var(--text-main); padding: 12px 14px; font-size: 1rem; }
.notice-form input:focus, .notice-form select:focus, .notice-form textarea:focus { outline: none; border-color: var(--accent-color); }
.notice-form textarea { resize: vertical; min-height: 140px; }
.notice-submit-btn { justify-self: start; }
.empty-state { color: var(--text-muted); }
@media (max-width: 1100px) {
    .metric-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .portal-grid { grid-template-columns: 1fr; }
}
@media (max-width: 720px) {
    .super-admin-page { margin-top: 24px; }
    .portal-hero { flex-direction: column; }
    .portal-badge { text-align: left; min-width: 0; width: 100%; }
    .metric-grid { grid-template-columns: 1fr; }
    .activity-row, .table-row { flex-direction: column; }
    .activity-meta, .row-meta { text-align: left; }
    .row-actions { justify-items: start; }
    .panel { padding: 18px; }
    .notice-form select,
    .notice-form input,
    .notice-form textarea { font-size: 0.96rem; }
    .notice-submit-btn,
    .promote-btn { width: 100%; }
}
@media (max-width: 520px) {
    .portal-hero h1 { font-size: 2.1rem; }
    .metric-card strong { font-size: 1.7rem; }
    .panel-header { flex-direction: column; align-items: flex-start; }
    .notice-form { gap: 14px; }
}
</style>

<script>
document.querySelectorAll('.promote-btn').forEach((button) => {
    button.addEventListener('click', async () => {
        if (!confirm('Promote this user to admin?')) {
            return;
        }

        try {
            const response = await fetch(`/super-admin/users/${button.dataset.userId}/promote`, { method: 'POST' });
            const data = await response.json();
            if (response.ok) {
                window.location.reload();
            } else {
                alert(data.message || 'Could not promote user.');
            }
        } catch (error) {
            console.error(error);
            alert('Could not promote user.');
        }
    });
});

const noticeForm = document.getElementById('notice-form');

if (noticeForm) {
    noticeForm.addEventListener('submit', async (event) => {
        event.preventDefault();

        const formData = new FormData(noticeForm);
        const userId = formData.get('userId');
        const subject = formData.get('subject');
        const message = formData.get('message');

        if (!userId) {
            alert('Choose a recipient first.');
            return;
        }

        try {
            const response = await fetch(`/super-admin/users/${userId}/notice`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ subject, message }),
            });

            const data = await response.json();
            if (response.ok) {
                noticeForm.reset();
                alert(data.message || 'Mail sent successfully.');
            } else {
                alert(data.message || 'Could not send mail.');
            }
        } catch (error) {
            console.error(error);
            alert('Could not send mail.');
        }
    });
}
</script>

<%- include('partials/footer') %>