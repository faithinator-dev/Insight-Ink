<%- include('partials/header') %>

<div class="min-h-[calc(100vh-64px)] flex items-center justify-center py-12 px-4">
    <div class="w-full max-w-md">
        <!-- Welcome Card -->
        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-8">
            <div class="text-center mb-8">
                <div class="w-16 h-16 bg-gradient-to-br from-indigo-400 to-indigo-600 rounded-full mx-auto mb-4 flex items-center justify-center">
                    <i class="fas fa-sign-in-alt text-white text-2xl"></i>
                </div>
                <h1 class="text-3xl font-bold text-slate-900 mb-2">Welcome back</h1>
                <p class="text-slate-600">Sign in to your Insight-Ink account</p>
            </div>

            <form id="login-form" class="space-y-5">
                <!-- Email Input -->
                <div id="email-group">
                    <label class="block text-sm font-medium text-slate-700 mb-2">Email address</label>
                    <input type="email" name="email" required placeholder="name@example.com"
                        class="w-full px-4 py-3 rounded-lg border border-slate-300 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 outline-none transition">
                    <span class="hidden text-sm text-red-600 mt-1">Invalid email address</span>
                </div>

                <!-- Password Input -->
                <div id="password-group">
                    <label class="block text-sm font-medium text-slate-700 mb-2">Password</label>
                    <div class="relative">
                        <input type="password" name="password" id="login-password" required placeholder="••••••••"
                            class="w-full px-4 py-3 rounded-lg border border-slate-300 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 outline-none transition">
                        <button type="button" id="toggle-password" class="absolute right-3 top-3 text-slate-500 hover:text-slate-700">
                            <i class="far fa-eye text-lg"></i>
                        </button>
                    </div>
                    <span class="hidden text-sm text-red-600 mt-1">Password is required</span>
                </div>

                <!-- Submit Button -->
                <button type="submit" id="login-btn" class="w-full px-4 py-3 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 font-medium transition flex items-center justify-center gap-2">
                    <span id="btn-text">Sign in</span>
                </button>
            </form>

            <!-- Switch to Register -->
            <p class="text-center text-slate-600 text-sm mt-6">
                No account yet? <a href="/register" class="text-indigo-600 hover:text-indigo-700 font-medium">Create one</a>
            </p>
        </div>
    </div>
</div>

<script>
// Toggle Password Visibility
const togglePassword = document.getElementById('toggle-password');
const passwordInput = document.getElementById('login-password');

togglePassword.addEventListener('click', () => {
    const type = passwordInput.getAttribute('type') === 'password' ? 'text' : 'password';
    passwordInput.setAttribute('type', type);
    togglePassword.classList.toggle('fa-eye');
    togglePassword.classList.toggle('fa-eye-slash');
});

document.getElementById('login-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const loginBtn = document.getElementById('login-btn');
    const btnText = document.getElementById('btn-text');
    const emailGroup = document.getElementById('email-group');
    const passwordGroup = document.getElementById('password-group');

    // Reset errors
    emailGroup.classList.remove('error');
    passwordGroup.classList.remove('error');

    const email = e.target.email.value;
    const password = e.target.password.value;

    // Loading state
    loginBtn.disabled = true;
    btnText.innerHTML = '<span class="loader"></span> Signing in...';

    try {
        const res = await fetch('/api/login', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email, password })
        });

        const data = await res.json();

        if (res.ok) {
            window.location.href = '/';
        } else {
            // Validation feedback
            if (data.message.toLowerCase().includes('email')) emailGroup.classList.add('error');
            else if (data.message.toLowerCase().includes('password') || data.message.toLowerCase().includes('credentials')) passwordGroup.classList.add('error');
            
            alert(data.message || 'Login failed');
        }
    } catch (err) {
        console.error('Fetch error:', err);
        alert('An error occurred. Please try again.');
    } finally {
        // Reset loading state
        loginBtn.disabled = false;
        btnText.innerText = 'Sign In';
    }
});
</script>

<%- include('partials/footer') %>
