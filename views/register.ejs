<%- include('partials/header') %>

<div class="min-h-[calc(100vh-64px)] flex items-center justify-center py-12 px-4">
    <div class="w-full max-w-md">
        <!-- Welcome Card -->
        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-8">
            <div class="text-center mb-8">
                <div class="w-16 h-16 bg-gradient-to-br from-emerald-400 to-emerald-600 rounded-full mx-auto mb-4 flex items-center justify-center">
                    <i class="fas fa-user-plus text-white text-2xl"></i>
                </div>
                <h1 class="text-3xl font-bold text-slate-900 mb-2">Join us</h1>
                <p class="text-slate-600">Create your Insight-Ink account in seconds</p>
            </div>

            <form id="register-form" class="space-y-5">
                <!-- Name Input -->
                <div id="name-group">
                    <label class="block text-sm font-medium text-slate-700 mb-2">Full name</label>
                    <input type="text" name="name" required placeholder="John Doe"
                        class="w-full px-4 py-3 rounded-lg border border-slate-300 focus:border-emerald-500 focus:ring-2 focus:ring-emerald-100 outline-none transition">
                    <span class="hidden text-sm text-red-600 mt-1">Name is required</span>
                </div>

                <!-- Email Input -->
                <div id="email-group">
                    <label class="block text-sm font-medium text-slate-700 mb-2">Email address</label>
                    <input type="email" name="email" required placeholder="name@example.com"
                        class="w-full px-4 py-3 rounded-lg border border-slate-300 focus:border-emerald-500 focus:ring-2 focus:ring-emerald-100 outline-none transition">
                    <span class="hidden text-sm text-red-600 mt-1">Valid email is required</span>
                </div>

                <!-- Password Input -->
                <div id="password-group">
                    <label class="block text-sm font-medium text-slate-700 mb-2">Password</label>
                    <div class="relative">
                        <input type="password" name="password" id="reg-password" required minlength="6" placeholder="Min. 6 characters"
                            class="w-full px-4 py-3 rounded-lg border border-slate-300 focus:border-emerald-500 focus:ring-2 focus:ring-emerald-100 outline-none transition">
                        <button type="button" id="toggle-password" class="absolute right-3 top-3 text-slate-500 hover:text-slate-700">
                            <i class="far fa-eye text-lg"></i>
                        </button>
                    </div>
                    <span class="hidden text-sm text-red-600 mt-1">Password must be at least 6 characters</span>
                </div>

                <!-- Submit Button -->
                <button type="submit" id="reg-btn" class="w-full px-4 py-3 bg-emerald-600 text-white rounded-lg hover:bg-emerald-700 font-medium transition flex items-center justify-center gap-2">
                    <span id="btn-text">Create account</span>
                </button>
            </form>

            <!-- Switch to Login -->
            <p class="text-center text-slate-600 text-sm mt-6">
                Already have an account? <a href="/login" class="text-emerald-600 hover:text-emerald-700 font-medium">Sign in</a>
            </p>
        </div>
    </div>
</div>

<script>
// Toggle Password Visibility
const togglePassword = document.getElementById('toggle-password');
const passwordInput = document.getElementById('reg-password');

togglePassword.addEventListener('click', () => {
    const type = passwordInput.getAttribute('type') === 'password' ? 'text' : 'password';
    passwordInput.setAttribute('type', type);
    togglePassword.classList.toggle('fa-eye');
    togglePassword.classList.toggle('fa-eye-slash');
});

document.getElementById('register-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const regBtn = document.getElementById('reg-btn');
    const btnText = document.getElementById('btn-text');
    const groups = ['name-group', 'email-group', 'password-group'];
    
    // Reset errors
    groups.forEach(id => document.getElementById(id).classList.remove('error'));

    const name = e.target.name.value;
    const email = e.target.email.value;
    const password = e.target.password.value;

    // Loading state
    regBtn.disabled = true;
    btnText.innerHTML = '<span class="loader"></span> Creating account...';

    try {
        const res = await fetch('/api/register', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ name, email, password })
        });

        const data = await res.json();

        if (res.ok) {
            window.location.href = '/';
        } else {
            // Simple validation feedback based on message
            if (data.message.toLowerCase().includes('name')) document.getElementById('name-group').classList.add('error');
            if (data.message.toLowerCase().includes('email')) document.getElementById('email-group').classList.add('error');
            if (data.message.toLowerCase().includes('password')) document.getElementById('password-group').classList.add('error');
            
            alert(data.message || 'Registration failed');
        }
    } catch (err) {
        console.error('Fetch error:', err);
        alert('An error occurred. Please try again.');
    } finally {
        regBtn.disabled = false;
        btnText.innerText = 'Sign Up';
    }
});
</script>

<%- include('partials/footer') %>
