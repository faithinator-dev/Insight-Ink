<%- include('partials/header') %>

<div class="min-h-screen bg-gradient-to-b from-slate-50 to-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8 sm:py-12">
        <!-- Header -->
        <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-6 mb-8">
            <div>
                <h1 class="text-4xl sm:text-5xl font-bold text-slate-900 mb-3">Inbox</h1>
                <p class="text-lg text-slate-600">Notifications, likes, and interactions</p>
            </div>
            <div class="bg-white border border-slate-200 rounded-2xl p-6 shadow-sm min-w-max">
                <p class="text-sm font-medium text-slate-500 mb-2">Unread</p>
                <p class="text-3xl font-bold text-indigo-600"><%= (notifications && notifications.filter(n => !n.read).length) || 0 %></p>
            </div>
        </div>

        <!-- Notifications List -->
        <% if (notifications && notifications.length > 0) { %>
            <div class="space-y-3">
                <% notifications.forEach(notification => { %>
                    <article class="bg-white rounded-xl border <%= notification.read ? 'border-slate-200 opacity-75' : 'border-indigo-200 bg-gradient-to-r from-white to-indigo-50' %> p-6 hover:shadow-md transition-shadow duration-200">
                        <div class="flex items-start justify-between gap-4">
                            <div class="flex-1">
                                <div class="flex items-center gap-3 mb-2">
                                    <h3 class="font-semibold text-slate-900 text-lg"><%= notification.title %></h3>
                                    <% if (!notification.read) { %>
                                        <span class="px-3 py-1 bg-indigo-100 text-indigo-700 text-xs font-medium rounded-full">New</span>
                                    <% } %>
                                </div>
                                <p class="text-slate-700 mb-3 leading-relaxed"><%= notification.message %></p>
                                <p class="text-sm text-slate-500">
                                    <i class="fas fa-clock mr-2"></i><%= new Date(notification.createdAt).toLocaleString() %>
                                </p>
                            </div>
                            <% if (!notification.read) { %>
                                <button type="button" class="mark-read-btn px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white font-medium rounded-lg transition-colors duration-200 whitespace-nowrap flex-shrink-0" data-id="<%= notification._id %>">
                                    Mark read
                                </button>
                            <% } else { %>
                                <span class="px-4 py-2 bg-slate-100 text-slate-600 font-medium rounded-lg flex-shrink-0">Read</span>
                            <% } %>
                        </div>
                    </article>
                <% }) %>
            </div>
        <% } else { %>
            <div class="text-center py-16">
                <div class="mb-4">
                    <i class="fas fa-inbox text-5xl text-slate-300"></i>
                </div>
                <h3 class="text-xl font-semibold text-slate-600 mb-2">No notifications yet</h3>
                <p class="text-slate-500">When someone likes or comments on your posts, you'll see it here.</p>
            </div>
        <% } %>
    </div>
</div>

<script>
document.querySelectorAll('.mark-read-btn').forEach((button) => {
    button.addEventListener('click', async () => {
        const notificationId = button.dataset.id;
        try {
            const response = await fetch(`/api/notifications/${notificationId}/read`, { method: 'PUT' });
            const data = await response.json();
            if (response.ok) {
                const article = button.closest('article');
                article.classList.remove('border-indigo-200', 'bg-gradient-to-r', 'from-white', 'to-indigo-50');
                article.classList.add('border-slate-200', 'opacity-75');
                button.parentElement.innerHTML = '<span class="px-4 py-2 bg-slate-100 text-slate-600 font-medium rounded-lg">Read</span>';
            } else {
                alert(data.message || 'Could not mark message read.');
            }
        } catch (error) {
            console.error(error);
            alert('Could not mark message read.');
        }
    });
});
</script>

<%- include('partials/footer') %>